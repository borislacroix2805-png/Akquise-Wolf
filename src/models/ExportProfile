export type ExportTarget =
  | 'excel'
  | 'csv'
  | 'hubspot'
  | 'salesforce'
  | 'pipedrive'
  | 'zoho'
  | 'dynamics'
  | 'api'
  | 'webhook';

export type ExportArea = 'lead' | 'network';

export type ExportProfileStatus = 'active' | 'inactive' | 'draft';

export interface ExportFieldMapping {
  sourceField: string;
  targetField: string;
  required?: boolean;
}

export interface ExportFilter {
  onlyQualified?: boolean;
  onlyNotExported?: boolean;
  area?: ExportArea;
  owner?: string;
  createdFrom?: string;
  createdTo?: string;
  tags?: string[];
}

export interface ExportProfile {
  id: string;

  name: string;

  target: ExportTarget;

  area: ExportArea;

  status: ExportProfileStatus;

  fieldMappings: ExportFieldMapping[];

  filters: ExportFilter;

  lastExportAt?: string;

  createdAt: string;
  updatedAt: string;
}

