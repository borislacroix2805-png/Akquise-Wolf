import { ExportArea, ExportTarget } from './ExportProfile';

export type ExportJobStatus =
  | 'pending'
  | 'running'
  | 'completed'
  | 'failed'
  | 'cancelled';

export interface ExportJobError {
  contactId?: string;
  field?: string;
  message: string;
}

export interface ExportJob {
  id: string;

  profileId?: string;

  target: ExportTarget;

  area: ExportArea;

  status: ExportJobStatus;

  totalRecords: number;
  exportedRecords: number;
  skippedRecords: number;
  errorRecords: number;

  errors: ExportJobError[];

  fileName?: string;

  startedAt?: string;
  completedAt?: string;

  createdBy?: string;

  createdAt: string;
  updatedAt: string;
}

export const exportJobStatusLabels: Record<ExportJobStatus, string> = {
  pending: 'Wartet',
  running: 'Läuft',
  completed: 'Abgeschlossen',
  failed: 'Fehlgeschlagen',
  cancelled: 'Abgebrochen',
};
