import { ImportSource, ImportTargetArea } from './ImportProfile';

export type ImportJobStatus =
  | 'pending'
  | 'running'
  | 'completed'
  | 'failed'
  | 'cancelled';

export interface ImportJobError {
  row?: number;
  field?: string;
  message: string;
}

export interface ImportJob {
  id: string;

  profileId?: string;

  source: ImportSource;

  targetArea: ImportTargetArea;

  fileName?: string;

  status: ImportJobStatus;

  totalRows: number;
  importedRows: number;
  skippedRows: number;
  updatedRows: number;
  errorRows: number;

  errors: ImportJobError[];

  startedAt?: string;
  completedAt?: string;

  createdBy?: string;

  createdAt: string;
  updatedAt: string;
}

export const importJobStatusLabels: Record<ImportJobStatus, string> = {
  pending: 'Wartet',
  running: 'Läuft',
  completed: 'Abgeschlossen',
  failed: 'Fehlgeschlagen',
  cancelled: 'Abgebrochen',
};
